theme: dark
default_redirection_url: http://192.168.1.87:9000

server:
  address: 'tcp://:9091'

log:
  level: info

totp:
  issuer: nebulacorvi.com

authentication_backend:
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id

access_control:
  default_policy: one_factor

session:
  secret: {{ authelia_session_secret }}
  redis:
    host: redis
    port: 6379
    password: {{ redis_password }}
  cookies:
    - domain: nebula.local
      authelia_url: http://192.168.1.87:9091

storage:
  encryption_key: {{ authelia_storage_key }}
  local:
    path: /config/db.sqlite3

notifier:
  filesystem:
    filename: /config/notification.txt