services:
  authelia:
    image: authelia/authelia:latest
    container_name: authelia
    restart: unless-stopped
    ports:
      - "9091:9091"
    volumes:
      - {{ nebula_base_path }}/authelia/config:/config
    networks: [proxy]
    labels:
      - traefik.enable=true
      - traefik.http.routers.authelia.rule=Host(`auth.{{ active_domain }}`)
      - traefik.http.routers.authelia.entrypoints=web
      - traefik.http.services.authelia.loadbalancer.server.port=9091
networks:
  proxy:
    external: true