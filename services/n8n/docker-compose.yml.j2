services:
  n8n:
    image: n8nio/n8n:latest
    container_name: n8n
    restart: unless-stopped
    ports:
      - "5678:5678"
    environment:
      - N8N_SECURE_COOKIE=false
    volumes:
      - {{ nebula_base_path }}/n8n/data:/home/node/.n8n
    networks: [proxy]

networks:
  proxy:
    external: true