services:
  penpot-db:
    image: postgres:15-alpine
    container_name: penpot-db
    restart: unless-stopped
    environment:
      - POSTGRES_USER=penpot
      - POSTGRES_PASSWORD={{ penpot_db_password }}
      - POSTGRES_DB=penpot
    volumes:
      - {{ data_path }}/penpot/db:/var/lib/postgresql/data
    networks: [proxy]

  penpot-redis:
    image: redis:7-alpine
    container_name: penpot-redis
    restart: unless-stopped
    networks: [proxy]

  penpot-backend:
    image: penpotapp/backend:latest
    container_name: penpot-backend
    restart: unless-stopped
    depends_on: [penpot-db, penpot-redis]
    environment:
      - PENPOT_FLAGS=disable-email-verification disable-registration disable-login-with-password
      - PENPOT_PUBLIC_URI=http://design.{{ active_domain }}
      - PENPOT_DATABASE_URI=postgresql://penpot:{{ penpot_db_password }}@penpot-db/penpot
      - PENPOT_DATABASE_USERNAME=penpot
      - PENPOT_DATABASE_PASSWORD={{ penpot_db_password }}
      - PENPOT_REDIS_URI=redis://penpot-redis/0
      - PENPOT_SECRET_KEY={{ penpot_secret_key }}
    networks: [proxy]

  penpot-frontend:
    image: penpotapp/frontend:latest
    container_name: penpot-frontend
    restart: unless-stopped
    depends_on: [penpot-backend]
    networks: [proxy]
    labels:
      - traefik.enable=true
      - traefik.http.routers.penpot.rule=Host(`design.{{ active_domain }}`)
      - traefik.http.routers.penpot.entrypoints=web
      - traefik.http.services.penpot.loadbalancer.server.port=80

networks:
  proxy:
    external: true