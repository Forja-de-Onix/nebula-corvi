services:
  db:
    image: mariadb:11
    container_name: nextcloud-db
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: "{{ nextcloud_db_root_password }}"
      MYSQL_DATABASE: nextcloud
      MYSQL_USER: nextcloud
      MYSQL_PASSWORD: "{{ nextcloud_db_password }}"
    volumes:
      - {{ nebula_base_path }}/nextcloud/db:/var/lib/mysql
    networks: [proxy]

  nextcloud-cache:
    image: redis:alpine
    container_name: nextcloud-redis
    restart: unless-stopped
    networks: [proxy]

  app:
    image: nextcloud:latest
    container_name: nextcloud
    restart: unless-stopped
    depends_on: [db, nextcloud-cache]
    ports:
      - "8081:80"
    environment:
      MYSQL_HOST: db
      MYSQL_DATABASE: nextcloud
      MYSQL_USER: nextcloud
      MYSQL_PASSWORD: "{{ nextcloud_db_password }}"
      REDIS_HOST: nextcloud-redis
      OVERWRITECLIURL: "http://nube.{{ active_domain }}"
    volumes:
      - {{ data_path }}/nextcloud:/var/www/html
    networks: [proxy]
    labels:
      - traefik.enable=true
      - traefik.http.routers.nextcloud.rule=Host(`nube.{{ active_domain }}`)
      - traefik.http.routers.nextcloud.entrypoints=web
      - traefik.http.services.nextcloud.loadbalancer.server.port=80

networks:
  proxy:
    external: true