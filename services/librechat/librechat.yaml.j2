version: 1.1.5
cache: true
endpoints:
  custom:
    - name: "Ollama"
      apiKey: "ollama"
      baseURL: "http://{{ ansible_default_ipv4.address }}:11434/v1/"
      models:
        default: [ "hecate:latest" ]
        fetch: true
      titleConvo: true
      titleModel: "current_model"
      summarize: false
      summaryModel: "current_model"
      modelDisplayLabel: "Ollama"