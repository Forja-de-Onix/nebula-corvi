services:
  portainer:
    image: portainer/portainer-ce:latest
    container_name: portainer
    restart: unless-stopped
    ports:
      - "9000:9000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ nebula_base_path }}/portainer/data:/data
    networks: [proxy]

networks:
  proxy:
    external: true