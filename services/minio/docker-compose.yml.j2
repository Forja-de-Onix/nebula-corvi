services:
  minio:
    image: minio/minio:latest
    container_name: minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    ports:
      - "9001:9001"
      - "9002:9000"
    environment:
      MINIO_ROOT_USER: admin
      MINIO_ROOT_PASSWORD: "{{ minio_root_password }}"
    volumes:
      - {{ data_path }}/minio:/data
    networks: [proxy]

networks:
  proxy:
    external: true