services:
  gitea-db:
    image: postgres:16-alpine
    container_name: gitea-db
    restart: unless-stopped
    environment:
      POSTGRES_USER: gitea
      POSTGRES_PASSWORD: "{{ gitea_db_password }}"
      POSTGRES_DB: gitea
    volumes:
      - {{ nebula_base_path }}/gitea/db:/var/lib/postgresql/data
    networks: [proxy]

  gitea:
    image: gitea/gitea:latest
    container_name: gitea
    restart: unless-stopped
    depends_on: [gitea-db]
    ports:
      - "3001:3000"
      - "2222:22"
    environment:
      - GITEA__database__DB_TYPE=postgres
      - GITEA__database__HOST=gitea-db:5432
      - GITEA__database__NAME=gitea
      - GITEA__database__USER=gitea
      - GITEA__database__PASSWD={{ gitea_db_password }}
      - GITEA__server__DOMAIN=git.{{ active_domain }}
      - GITEA__server__ROOT_URL=http://git.{{ active_domain }}/
    volumes:
      - {{ data_path }}/gitea:/data
    networks: [proxy]
    labels:
      - traefik.enable=true
      - traefik.http.routers.gitea.rule=Host(`git.{{ active_domain }}`)
      - traefik.http.routers.gitea.entrypoints=web
      - traefik.http.services.gitea.loadbalancer.server.port=3000

networks:
  proxy:
    external: true