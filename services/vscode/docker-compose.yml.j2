services:
  vscode:
    image: lscr.io/linuxserver/code-server:latest
    container_name: vscode
    restart: unless-stopped
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Madrid
      - PASSWORD={{ vscode_password }}
      - SUDO_PASSWORD={{ vscode_password }}
      - DEFAULT_WORKSPACE=/config/workspace
    volumes:
      - {{ nebula_base_path }}/vscode/config:/config
    networks: [proxy]
    labels:
      - traefik.enable=true
      - traefik.http.routers.vscode.rule=Host(`code.{{ active_domain }}`)
      - traefik.http.routers.vscode.entrypoints=web
      - traefik.http.services.vscode.loadbalancer.server.port=8443

networks:
  proxy:
    external: true