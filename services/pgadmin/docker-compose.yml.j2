services:
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: pgadmin
    restart: unless-stopped
    ports:
      - "8978:80"
    environment:
      - PGADMIN_DEFAULT_EMAIL={{ admin_email }}
      - PGADMIN_DEFAULT_PASSWORD={{ pgadmin_password }}
    volumes:
      - {{ nebula_base_path }}/pgadmin/data:/var/lib/pgadmin
      - {{ nebula_base_path }}/pgadmin/servers.json:/pgadmin4/servers.json:ro
    networks: [proxy]
    labels:
      - traefik.enable=true
      - traefik.http.routers.pgadmin.rule=Host(`postgres.{{ active_domain }}`)
      - traefik.http.routers.pgadmin.entrypoints=web
      - traefik.http.services.pgadmin.loadbalancer.server.port=80

networks:
  proxy:
    external: true